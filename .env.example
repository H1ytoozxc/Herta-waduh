# Example environment file for local development.
#
# Copy to `.env` and fill in values. The `.env` file is loaded automatically
# by `herta-config` at process startup. NEVER commit real secrets.

# ----- Logging / telemetry -----
HERTA_LOG_LEVEL=INFO
HERTA_TELEMETRY__LOG_FORMAT=pretty
HERTA_TELEMETRY__METRICS_ENABLED=true
HERTA_TELEMETRY__TRACING_ENABLED=false
HERTA_TELEMETRY__ENVIRONMENT=dev

# ----- HTTP server -----
HERTA_SERVER__ENABLED=true
HERTA_SERVER__BIND=127.0.0.1:9090

# ----- LLM selection -----
HERTA_LLM_PROVIDER=ollama

# Ollama
HERTA_OLLAMA__HOST=http://127.0.0.1:11434
HERTA_OLLAMA__MODEL=qwen3:4b
HERTA_OLLAMA__TEMPERATURE=0.55

# DeepSeek (secret)
# HERTA_DEEPSEEK__API_KEY=

# Google AI (secret)
# HERTA_GOOGLE_AI__API_KEY=
# HERTA_GOOGLE_AI__MODEL=gemma-3-27b-it

# ----- STT -----
HERTA_STT_PROVIDER=whisper
# HERTA_GOOGLE_STT__API_KEY=
HERTA_GOOGLE_STT__LANGUAGE_HINT=ru

# ----- Memory -----
HERTA_MEMORY__ENABLED=true
HERTA_MEMORY__BACKEND=json
HERTA_MEMORY__PATH=data/dialogue_memory.json
HERTA_MEMORY__MAX_MESSAGES=80
HERTA_MEMORY__CONTEXT_MESSAGES=12

# ----- Audio -----
HERTA_AUDIO__SAMPLE_RATE=16000
HERTA_AUDIO__CHANNELS=1
HERTA_AUDIO__BLOCK_SIZE=512
# HERTA_AUDIO__DEVICE=fifine
